# Production builds: set the public API base (no trailing slash).
# VITE_API_URL=https://api.example.com

# Local dev (npm run dev): leave VITE_API_URL unset to use same-origin /api (Vite proxy, avoids CORS).
# Override only if you need a direct URL:
# VITE_API_URL=http://127.0.0.1:8080

# Where the dev proxy forwards /api (match `uv run uvicorn ... --port`).
# VITE_DEV_API_TARGET=http://127.0.0.1:8080
