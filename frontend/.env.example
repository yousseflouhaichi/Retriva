# Call the API in the browser (backend must allow your page origin via CORS).
# Match the host and port where you run uvicorn (often 8000 or 8080).
VITE_API_URL=http://127.0.0.1:8000

# Same-origin dev proxy (avoids CORS): Vite forwards /api/* to the backend.
# Uncomment both lines and comment out VITE_API_URL above to use this mode.
# VITE_API_URL=/api
# VITE_DEV_API_TARGET=http://127.0.0.1:8000
