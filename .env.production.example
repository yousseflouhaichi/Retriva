# Copy to .env on the server (repo root). Do not commit real secrets.
# Use with: docker compose -f deploy/docker-compose.prod.yml --env-file .env up -d --build
#
# Inside Compose, use Docker DNS names (not localhost).

ENVIRONMENT=production

OPENAI_API_KEY=
COHERE_API_KEY=

QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379
UNSTRUCTURED_API_URL=http://unstructured:8000

# Must match the uploads volume mount in deploy/docker-compose.prod.yml
UPLOAD_DIR=/app/uploads

# Optional: extra browser origins if you split frontend/API across domains
# CORS_EXTRA_ALLOW_ORIGINS=

# --- Same tuning keys as .env.example (optional) ---
EMBEDDING_BATCH_SIZE=16
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
TIKTOKEN_ENCODING=cl100k_base
UNSTRUCTURED_TIMEOUT_SECONDS=120
INGESTION_JOB_TIMEOUT_BUFFER_SECONDS=180
STATUS_DEPENDENCY_TIMEOUT_SECONDS=3
QDRANT_UPSERT_BATCH_SIZE=64
DOCUMENT_LIST_SCROLL_BATCH_SIZE=256
DOCUMENT_INDEX_MAX_POINTS_SCANNED=50000
DOCUMENT_LIST_DEFAULT_LIMIT=100
DOCUMENT_LIST_MAX_LIMIT=500
BM25_MAX_CORPUS_DOCUMENTS=50000
QUERY_TRANSFORM_MODEL=gpt-4o-mini
MULTI_QUERY_COUNT=3
DENSE_TOP_K_PER_SUBQUERY=20
BM25_TOP_K=30
RRF_K=60
RERANK_CANDIDATE_POOL=48
COHERE_RERANK_MODEL=rerank-v3.5
RERANK_TOP_N=8
QUERY_ANSWER_MODEL=gpt-4o-mini
QUERY_ANSWER_MAX_TOKENS=1024
